# Configuração de E-mail (SMTP)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu-email@exemplo.com
SMTP_PASS=sua-senha
SMTP_SECURE=false
SMTP_FROM="Plataforma ONG <no-reply@ong.com>"

# Frontend URL (usado para CORS em produção e links nos e-mails)
# Em produção (Render), use a URL do Vercel. Múltiplas URLs separadas por vírgula.
# Exemplo: https://plataforma-ong.vercel.app
FRONTEND_URL=http://localhost:8080

# Banco de Dados MySQL
# Opção 1: URL única (recomendado para TiDB Cloud/PlanetScale/serviços cloud)
# No Render, configure esta variável de ambiente com a string de conexão real.
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/BANCO
# Exemplo TiDB Cloud: mysql://user.root:senha@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/test
# DATABASE_URL=
#
# Opção 2: Variáveis individuais (para desenvolvimento local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=plataforma_ong
DB_USER=ong_user
DB_PASSWORD=123456

# Servidor
PORT=3003
NODE_ENV=development

# Sincronização do Banco de Dados
# Defina como "true" para permitir que o Sequelize crie/atualize tabelas automaticamente
# Use na primeira vez que conectar ao TiDB Cloud para criar as tabelas
# Depois que as tabelas estiverem criadas, remova ou mude para "false"
# ALLOW_DB_SYNC=true

# Segurança
JWT_SECRET=segredo_jwt_temporario_123456
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
