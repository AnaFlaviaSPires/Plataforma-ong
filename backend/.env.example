# Configuração de E-mail (SMTP)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu-email@exemplo.com
SMTP_PASS=sua-senha
SMTP_SECURE=false
SMTP_FROM="Plataforma ONG <no-reply@ong.com>"

# Frontend URL (para links nos e-mails)
FRONTEND_URL=http://localhost:8080

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=plataforma_ong
DB_USER=ong_user
DB_PASSWORD=123456

# Servidor
PORT=3003
NODE_ENV=development

# Segurança
JWT_SECRET=segredo_jwt_temporario_123456
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
